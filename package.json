{
  "name": "@monid-ai/cli",
  "version": "0.0.1",
  "description": "Monid CLI — discover, inspect, and run data endpoints",
  "type": "module",
  "bin": {
    "monid": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run ./src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "monid",
    "cli",
    "data",
    "api",
    "scraping",
    "endpoints"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monid-ai/monid-cli.git"
  },
  "dependencies": {
    "@cliffy/command": "npm:@jsr/cliffy__command",
    "@cliffy/prompt": "npm:@jsr/cliffy__prompt",
    "@cliffy/table": "npm:@jsr/cliffy__table",
    "chalk": "^5.6.2",
    "conf": "^15.1.0",
    "ora": "^9.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
